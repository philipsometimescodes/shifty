{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-client",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"client",
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
